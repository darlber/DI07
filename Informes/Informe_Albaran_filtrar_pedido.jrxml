<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Listado_clientes" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="80519013-e829-455c-9670-01cdd8b95d61">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Fabrica"/>
	<parameter name="filtrar_pedido" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    c.Nombre AS cliente_nombre,
    c.Direccion AS cliente_direccion,
    c.Ciudad AS cliente_ciudad,
    e.Email AS cliente_email,
    t.Telefono AS cliente_telefono,
    p.ID_Pedido,
    p.Fecha_Pedido,
    a.Descripcion AS articulo,
    dp.Unidades,
    dp.Precio AS coste_unitario
FROM pedidos p
JOIN clientes c ON p.ID_Cliente = c.ID_Cliente
LEFT JOIN emails e ON e.Id_cliente = c.ID_Cliente
LEFT JOIN telefonos t ON t.Id_Cliente = c.ID_Cliente
JOIN detalle_pedidos dp ON dp.ID_Pedido = p.ID_Pedido
JOIN articulos a ON a.Id_articulo = dp.ID_Articulo
WHERE p.ID_Pedido = $P{filtrar_pedido}
ORDER BY cliente_nombre ASC, p.ID_Pedido ASC;]]>
	</queryString>
